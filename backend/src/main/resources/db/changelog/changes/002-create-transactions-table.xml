<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-transactions-table" author="hasan.ahmad">
        <createTable tableName="transactions">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="source_account_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_transactions_source_account" referencedTableName="accounts" referencedColumnNames="id"/>
            </column>
            <column name="destination_account_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_transactions_destination_account" referencedTableName="accounts" referencedColumnNames="id"/>
            </column>
            <column name="amount" type="numeric(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="varchar(3)">
                <constraints nullable="false"/>
            </column>
            <column name="transaction_date" type="timestamptz">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="idempotency_key" type="varchar(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_transactions_idempotency_key"/>
            </column>
        </createTable>

        <createIndex tableName="transactions" indexName="idx_transactions_source_account_id">
            <column name="source_account_id"/>
        </createIndex>
        <createIndex tableName="transactions" indexName="idx_transactions_status">
            <column name="status"/>
        </createIndex>

        <rollback>
            <dropTable tableName="transactions"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
